<!-- 平滑滾動 + 導航高亮簡易效果 -->
<script>
    // 平滑滾動處理（避免默認跳動），並更新導航活動樣式（簡單高亮）
    document.querySelectorAll('.nav-links a, .btn-hero, .back2top, .more-link, .btn-outline').forEach(anchor => {
        if(anchor.getAttribute('href') && anchor.getAttribute('href').startsWith('#')) {
            anchor.addEventListener('click', function(e) {
                const targetId = this.getAttribute('href');
                if(targetId === '#') return;
                const targetElement = document.querySelector(targetId);
                if(targetElement) {
                    e.preventDefault();
                    targetElement.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                    // 更新URL hash (選用)
                    history.pushState(null, null, targetId);
                }
            });
        }
    });
    // 主動式導航欄當前位置高亮(純視覺加強)
    const sections = document.querySelectorAll('section[id], #about, #news, #services, #contact');
    const navLinks = document.querySelectorAll('.nav-links a');
    window.addEventListener('scroll', () => {
        let current = '';
        const scrollPos = window.scrollY + 100;
        sections.forEach(section => {
            const sectionTop = section.offsetTop;
            const sectionHeight = section.offsetHeight;
            if(scrollPos >= sectionTop && scrollPos < sectionTop + sectionHeight) {
                current = section.getAttribute('id');
            }
        });
        navLinks.forEach(link => {
            link.style.color = '#e2e8f0';
            link.style.borderBottomColor = 'transparent';
            if(link.getAttribute('href') === `#${current}`) {
                link.style.color = '#ffcd4a';
                link.style.borderBottomColor = '#ffcd4a';
            }
        });
    });
    // 防止點擊後沒高亮修正初始
    window.dispatchEvent(new Event('scroll'));
</script>
</body>
</html>
